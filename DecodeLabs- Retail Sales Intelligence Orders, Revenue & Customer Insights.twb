      <column caption='Average order value' datatype='real' name='[Calculation_0107485519720448]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPrice]) / COUNT([OrderID])' />
      </column>
      <column caption='Cancelled orders' datatype='integer' name='[Calculation_0107485520330753]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [OrderStatus] = &quot;Cancelled&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Cancel Rate' datatype='real' name='[Calculation_0107485520674818]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [OrderStatus] = &quot;Cancelled&quot; THEN 1 ELSE 0 END) / COUNT([OrderID])' />
